# Base de datos principal (Neon.tech)
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Base de datos sombra para migraciones (puede ser la misma que DATABASE_URL)
SHADOW_DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Entorno de ejecución
NODE_ENV="production"

# Configuraciones opcionales
LOG_LEVEL="info"
BATCH_SIZE="50" 