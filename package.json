    "prisma-deploy": "prisma db push",
    "render-build": "npm install && npm run build && npm run prisma-generate"
  },
  "dependencies": {
    "prisma": "6.3.0",
    "@prisma/client": "6.3.0",
    "express": "4.17.1",
    "xlsx": "^0.18.5",
    "typescript": "5.7.3",
    "ts-node": "10.4.0",
    "@types/node": "22.13.0",
    "dotenv": "^16.4.7",
    "@types/express": "4.17.13"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}